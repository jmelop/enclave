# Enclave — App URLs
# Copy this file to .env.local and fill in your server addresses.
# Vite exposes only variables prefixed with VITE_ to the client bundle.

VITE_PORTFOLIO_URL=http://192.168.1.x:8082
VITE_CALENDAR_URL=https://www.icloud.com/calendar/
VITE_TASK_MANAGER_URL=http://192.168.1.x:8081
VITE_SYSTEM_MONITOR_URL=http://192.168.1.x:3006
VITE_IDENTITY_VAULT_URL=http://192.168.1.x:3007
VITE_REMOTE_SYNC_URL=http://192.168.1.x:3008
VITE_BACKUP_SERVICE_URL=http://192.168.1.x:3009
VITE_SOCIAL_TRACKER_URL=http://192.168.1.x:3010
VITE_CYBER_INTEL_URL=http://192.168.1.x:3002
VITE_HEALTH_MONITOR_URL=http://192.168.1.x:3011
VITE_ACCESS_CONTROL_URL=http://192.168.1.x:3012
